{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Muse_Generator",
  "version": "1.0.0",
  "identifier": "com.muse.generator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Muse测试素材生成器",
        "width": 560,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png"]
  }
}
